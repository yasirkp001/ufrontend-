# API Base URL for Uclose Client Frontend
# For local development, leave it empty to use the Vite dev server proxy (which proxies /api to http://localhost:5000)
# For production, set it to the URL of the deployed backend (e.g., https://ubackend-guk8.onrender.com)
VITE_API_BASE_URL=https://ubackend-guk8.onrender.com

# Stripe Configuration
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Google Authentication
# Create a Google Web Application client ID in the Google Cloud Console (https://console.cloud.google.com/)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
